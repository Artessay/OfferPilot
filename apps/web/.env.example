# Copy to `.env` for local development: cp .env.example .env

# Base URL of the backend API (the browser calls this directly).
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Base path for the built site. Use "/" for a custom domain or root deploy,
# or "/<repo>/" for a GitHub Pages project site (e.g. /OfferPilot/).
VITE_BASE_PATH=/
