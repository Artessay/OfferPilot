# Copy to `.env` for local development: cp .env.example .env

# Data mode (build-time):
#   remote (default) — talk to the FastAPI backend over HTTP. Used for both the
#                      Postgres (full) and SQLite (lite) backend deployments.
#   local            — a fully in-browser build for static hosting (GitHub
#                      Pages). All data lives in IndexedDB and the deterministic
#                      AI runs on-device. No backend or API key required.
VITE_DATA_MODE=remote

# Base URL of the backend API (the browser calls this directly).
# Only used in remote mode; ignored when VITE_DATA_MODE=local.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Base path for the built site. Use "/" for a custom domain or root deploy,
# or "/<repo>/" for a GitHub Pages project site (e.g. /OfferPilot/).
VITE_BASE_PATH=/
