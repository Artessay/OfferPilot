# Copy to `.env` in this folder: cp .env.example .env
# docker compose reads these when bringing up the stack.

ENVIRONMENT=local

# Postgres
POSTGRES_USER=offerpilot
POSTGRES_PASSWORD=offerpilot
POSTGRES_DB=offerpilot
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=8000
JWT_SECRET=dev-secret-change-me
AI_PROVIDER=fake
LOG_JSON=true
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Web (browser-facing API URL + host port)
WEB_PORT=8080
VITE_API_BASE_URL=http://localhost:8000/api/v1
