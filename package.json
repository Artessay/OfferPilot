{
  "name": "offerpilot",
  "version": "0.1.0",
  "private": true,
  "description": "OfferPilot (Offer 捕手) — AI job-matching assistant for students. Monorepo root.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.0.3"
    }
  },
  "scripts": {
    "web:dev": "pnpm --filter @offerpilot/web dev",
    "web:build": "pnpm --filter @offerpilot/web build",
    "web:lint": "pnpm --filter @offerpilot/web lint",
    "web:test": "pnpm --filter @offerpilot/web test",
    "web:typecheck": "pnpm --filter @offerpilot/web typecheck"
  }
}
