# ---------------------------------------------------------------------------
# OfferPilot — shared environment example.
#
# Copy the per-service files instead of this one for local development:
#   cp services/api/.env.example services/api/.env
#   cp apps/web/.env.example apps/web/.env
#
# This root file documents the variables that infra/docker-compose.yml reads
# when bringing up the full stack. Override locally via a root `.env`.
# ---------------------------------------------------------------------------

# --- Postgres (used by docker-compose) ---
POSTGRES_USER=offerpilot
POSTGRES_PASSWORD=offerpilot
POSTGRES_DB=offerpilot
POSTGRES_PORT=5432

# --- Redis (used by docker-compose) ---
REDIS_PORT=6379

# --- API service ---
API_PORT=8000
# Public URL the browser uses to reach the API (consumed by the web build)
VITE_API_BASE_URL=http://localhost:8000/api/v1
